[filechooser]
cmd=/usr/share/xdg-desktop-portal-termfilechooser/yazi-wrapper.sh
default_dir=$HOME
; Uncomment to skip creating destination save files with instructions in them
; create_help_file=0
; Uncomment and edit the line below to change the terminal emulator command
env=TERMCMD=$(cat ~/.config/ml4w/settings/terminal.sh) --class dotfiles-floating -e yazi

; Mode must be one of 'suggested', 'default', or 'last'.
open_mode=suggested
save_mode=suggested
