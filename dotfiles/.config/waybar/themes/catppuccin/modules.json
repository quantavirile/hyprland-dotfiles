{
  // Workspaces
  "hyprland/workspaces": {
    "format": " {icon} ",
    "on-click": "activate",
    "format-icons": {
      "active": "оЃі",
      "empty": "пДМ",
      "default": "пДМ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  // Hyprland Window
  "hyprland/window": {
    "max-length": 60,
    "rewrite": {
      "(.*) вАФ Mozilla Firefox": "Firefox",
      "(.*) вАФ Zen Browser": "Zen Browser",
      "(.*) - Brave": "Brave",
      "(.*) - Notesnook": "Notesnook",
      "(.*) - FreeTube": "FreeTube",
      "(.*) - mpv": "mpv Media Player",
      "(.*) - VSCodium": "VSCodium",
      "Yazi.*": "Yazi",
      "class<kitty>": "Kitty" //Check this out
    },
    "separate-outputs": true
  },
  // Empty
  // "custom/empty": {
  //   "format": ""
  // },
  // Updates Count
  "custom/updates": {
    "format": "пЖ≤  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/scripts/updates.sh",
    "interval": 1800, // Check every 30 minutes
    "signal": 1,
    "hide-empty-text": true,
    "on-click": "~/.config/ml4w/settings/installupdates.sh"
  },
  // SwayNC
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "notifications_active",
      "none": "notifications",
      "dnd-notification": "notifications_active",
      "dnd-none": "notifications_paused",
      "inhibited-notification": "notification_important",
      "inhibited-none": "notification_important",
      "dnd-inhibited-notification": "notification_off",
      "dnd-inhibited-none": "notifications_off"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  // Hypridle inhibitor
  "custom/hypridle": {
    "format": "пА£",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle"
  },
  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
    "format": "{:%H:%M}",
    "on-click": "gnome-calendar",
    "timezone": "",
    "tooltip": false
  },
  // CPU
  "cpu": {
    "interval": 1,
    "format": "пТЉ  {usage}% ",
    "states": {
      "warning": 60,
      "critical": 80
    },
    "on-click": "~/.config/ml4w/settings/system-monitor.sh"
  },
  // Memory
  "memory": {
    "interval": 1,
    "format": "оњЕ  {}% ",
    "states": {
      "warning": 60,
      "critical": 80
    },
    "on-click": "~/.config/ml4w/settings/system-monitor.sh"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/system", "cpu", "memory"]
  },
  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/tools", "custom/hypridle", "power-profiles-daemon"]
  },
  // Network
  "network": {
    "format": "{bandwidthTotalBits} {ifname}",
    "format-wifi": "{bandwidthTotalBits} у∞§® ",
    "format-ethernet": "{bandwidthTotalBits} пЮЦ ",
    "format-disconnected": "",
    "tooltip-format": "пЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "у∞§® {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "пЮЦ {ifname}\nIP: {ipaddr}\nу∞ЬЈ {bandwidthUpBits} у∞ЬЃ {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    // "max-length": 50,
    "interval": 1,
    "on-click": "~/.config/ml4w/settings/networkmanager.sh"
  },
  // Battery
  "battery": {
    "interval": 1,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пЧІ {capacity}%",
    "format-plugged": "пЗ¶ {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-full": "",
    "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "]
  },
  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пЖЕ",
      "performance": "пГІ",
      "balanced": "п°£",
      "power-saver": "пБђ"
    }
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
    "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
    "format-muted": "пЪ© {format_source}",
    "format-source": "{volume}% пД∞",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА• ",
      "hands-free": "пЦР ",
      "headset": "пЦР ",
      "phone": "пВХ ",
      "portable": "пВХ ",
      "car": "пЖє ",
      "default": ["пА¶", "пА®", "пА®"]
    },
    "on-click": "pavucontrol"
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "оОН",
      "оПФ",
      "оПУ",
      "оПТ",
      "оПС",
      "оПР",
      "оПП",
      "оПО",
      "оПН",
      "оПМ",
      "оПЛ",
      "оПК",
      "оПЙ",
      "оПИ",
      "оОЫ"
    ],
    "scroll-step": 1
  },

  "mpris": {
    "format": "{player_icon} {dynamic}",
    "dynamic-len": 50,
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "format-stopped": "Nothing playing...",
    "interval": 1,
    "player-icons": {
      "default": "пБЛ",
      "mpv": "пЕД",
      "spotify": "пЖЉ",
      "org": "пЛО",
      "kasts": "пЛО"
    },
    "status-icons": {
      "paused": "пБМ"
    },
    "dynamic-order": ["artist", "title", "album"],
    "ignored-players": ["blanket"]
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пА£",
      "deactivated": "пЛЉ",
      "on-click": "~/.config/hypr/scripts/hypridle.sh toggle"
    }
  }
}
